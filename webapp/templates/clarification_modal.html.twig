{% set current_route = app.request.attributes.get('_route') %}
{% extends "partials/modal.html.twig" %}

{% block title %}
{% if team is defined and clarification.sender and clarification.sender.teamid == team.teamid %}
Clarification Request
{% else %}
View clarification
{% endif %}
{% endblock %}

{% block content %}
    {% include 'partials/clarification_content.html.twig' %}
{% endblock %}
{% block extraButton %}
    {% if current_route starts with 'team_' %}
        <button class="btn btn-secondary" data-bs-toggle="collapse" data-bs-target="#collapsereplyform"
                aria-expanded="false" aria-controls="collapsereplyform" id="clarification-reply-button">
            <i class="fa fa-reply"></i> reply to this clarification
        </button>
    {% endif %}
{% endblock %}
